PORT=3009
SECRET_KEY=change_this_secret
TIWATER_API_KEY=change_this_api_key

# ---------------------------------------------------------------------------
# Azure PostgreSQL Flexible Server (Australia East)
# Server name: tiwatermx-api-server
# Database:    tiwatermx-api-database
# Admin user:  rhuhvluvzl
# Host must be the FQDN (not the short "Server name" alone):
#   tiwatermx-api-server.postgres.database.azure.com
# If POSTGRES_HOST is missing on App Service, Node defaults to localhost → ECONNREFUSED 127.0.0.1:5432
# ---------------------------------------------------------------------------
POSTGRES_HOST=tiwatermx-api-server.postgres.database.azure.com
POSTGRES_PORT=5432
POSTGRES_DB=tiwatermx-api-database
POSTGRES_USER=rhuhvluvzl
POSTGRES_PASSWORD=<paste-admin-password-here>
POSTGRES_SSL=true

# Same server + database for products/quotes (tiwater_* tables). Override only if you split DBs later.
POSTGRES_TIWATER_HOST=tiwatermx-api-server.postgres.database.azure.com
POSTGRES_TIWATER_PORT=5432
POSTGRES_TIWATER_DB=tiwatermx-api-database
POSTGRES_TIWATER_USER=rhuhvluvzl
POSTGRES_TIWATER_PASSWORD=<paste-admin-password-here>
POSTGRES_TIWATER_SSL=true

# ---------------------------------------------------------------------------
# Local development (optional)
# ---------------------------------------------------------------------------
# POSTGRES_HOST=localhost
# POSTGRES_DB=tiwater_timeseries
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=
# POSTGRES_SSL=false
# POSTGRES_TIWATER_DB=ti_water
# POSTGRES_TIWATER_SSL=false
