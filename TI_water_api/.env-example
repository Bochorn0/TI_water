PORT=3009
# Required for /auth/login (JWT). On Azure App Service set Application setting SECRET_KEY.
SECRET_KEY=generate_with_openssl_rand_hex_32
TIWATER_API_KEY=change_this_api_key

# ---------------------------------------------------------------------------
# Email — see Aquatech_api/docs/EMAIL_CONFIG.md
# EMAIL_DISABLED=true or EMAIL_PROVIDER=none → no envío
# ---------------------------------------------------------------------------
# EMAIL_PROVIDER=mailgun
# MAILGUN_API_KEY=key-xxxxxxxx
# MAILGUN_DOMAIN=tiwater.mx
# MAILGUN_FROM_EMAIL=soporte@tiwater.mx
# FRONTEND_URL=https://tiwater.mx

# =============================================================================
# CHOOSE ONE BLOCK: local dev OR Azure production (in your local .env file only)
#
# Production secrets live in Azure App Service → Configuration → Application
# settings. Editing .env on your laptop does NOT change the deployed API.
# =============================================================================

# ---------------------------------------------------------------------------
# Local development — copy this block into .env for npm run dev on your machine
# ---------------------------------------------------------------------------
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=tiwater_timeseries
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=
# POSTGRES_SSL=false
# POSTGRES_TIWATER_HOST=localhost
# POSTGRES_TIWATER_PORT=5432
# POSTGRES_TIWATER_DB=tiwater_timeseries
# POSTGRES_TIWATER_USER=postgres
# POSTGRES_TIWATER_PASSWORD=
# POSTGRES_TIWATER_SSL=false
# EMAIL_DISABLED=true

# ---------------------------------------------------------------------------
# Azure PostgreSQL Flexible Server (Australia East) — production reference
# Server: tiwatermx-api-server.postgres.database.azure.com
# Database: tiwatermx-api-database  |  User: rhuhvluvzl
# Set these in Azure App Service Application settings (not in git).
# ---------------------------------------------------------------------------
POSTGRES_HOST=tiwatermx-api-server.postgres.database.azure.com
POSTGRES_PORT=5432
POSTGRES_DB=tiwatermx-api-database
POSTGRES_USER=rhuhvluvzl
POSTGRES_PASSWORD=<from-azure-portal-or-key-vault>
POSTGRES_SSL=true

POSTGRES_TIWATER_HOST=tiwatermx-api-server.postgres.database.azure.com
POSTGRES_TIWATER_PORT=5432
POSTGRES_TIWATER_DB=tiwatermx-api-database
POSTGRES_TIWATER_USER=rhuhvluvzl
POSTGRES_TIWATER_PASSWORD=<from-azure-portal-or-key-vault>
POSTGRES_TIWATER_SSL=true

# After migrations: admin@tiwater.mx / admin (or npm run seed:admin)
