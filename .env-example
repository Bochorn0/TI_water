# Local dev: point at TI_water_api (default port 3009)
VITE_API_BASE_URL=http://localhost:3009/api/v2.0
# Optional override; if unset, Vite uses VITE_API_BASE_URL + "/tiwater"
# VITE_API_BASE_URL_TIWATER=http://localhost:3009/api/v2.0/tiwater

# Must match App Service TIWATER_API_KEY (axios sends X-TIWater-API-Key for products + quote create)
VITE_TIWATER_API_KEY=your_key

# --- Azure Static Web Apps (GitHub Actions) ---
# Add these as repository Secrets so the build embeds the right API:
#   VITE_API_BASE_URL=https://YOUR-APP.azurewebsites.net/api/v2.0
#   VITE_TIWATER_API_KEY=<same as Azure App Service TIWATER_API_KEY>
# Optional: VITE_API_BASE_URL_TIWATER=https://YOUR-APP.azurewebsites.net/api/v2.0/tiwater

# Optional: HTTPS dev server certs for Vite
# VITE_HTTPS_KEY=/absolute/path/to/key.pem
# VITE_HTTPS_CERT=/absolute/path/to/cert.pem
