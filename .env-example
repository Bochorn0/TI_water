# Local dev: point at TI_water_api (default port 3009) — single version /api/v1.0
VITE_API_BASE_URL=http://localhost:3009/api/v1.0
# Optional override; if unset, Vite uses VITE_API_BASE_URL + "/tiwater"
# VITE_API_BASE_URL_TIWATER=http://localhost:3009/api/v1.0/tiwater

# Must match App Service TIWATER_API_KEY (axios sends X-TIWater-API-Key for products + quote create)
VITE_TIWATER_API_KEY=your_key

# --- Azure (production API) ---
# Health: https://tiwatermx-api-hgaua5f6bycshrc5.australiaeast-01.azurewebsites.net/api/v1.0/health
# API base for VITE_* (auth + data under /api/v1.0):
#   https://tiwatermx-api-hgaua5f6bycshrc5.australiaeast-01.azurewebsites.net/api/v1.0
#
# --- Azure Static Web Apps (GitHub Actions secrets) ---
#   VITE_API_BASE_URL=https://tiwatermx-api-hgaua5f6bycshrc5.australiaeast-01.azurewebsites.net/api/v1.0
#   VITE_TIWATER_API_KEY=<same as App Service TIWATER_API_KEY>
# Optional: VITE_API_BASE_URL_TIWATER=.../api/v1.0/tiwater

# Optional: HTTPS dev server certs for Vite
# VITE_HTTPS_KEY=/absolute/path/to/key.pem
# VITE_HTTPS_CERT=/absolute/path/to/cert.pem
