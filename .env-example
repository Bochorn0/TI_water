# API URLs - production uses Apache reverse proxy (no port)
VITE_API_BASE_URL=https://www.lcc.com.mx/api/v2.0
VITE_API_BASE_URL_TIWATER=https://www.lcc.com.mx/api/v2.0/tiwater

# Optional: HTTPS dev server certs for Vite
# VITE_HTTPS_KEY=/absolute/path/to/key.pem
# VITE_HTTPS_CERT=/absolute/path/to/cert.pem

# Optional: API key if needed
VITE_TIWATER_API_KEY=your_key
